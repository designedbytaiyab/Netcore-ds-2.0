  "font": {
    "family": {
      "primary": { "$value": "Nunito Sans", "$type": "fontFamily", "$description": "Primary UI font — ALL text across CEE platform" },
      "display": { "$value": "Nunito",      "$type": "fontFamily", "$description": "Numeric displays, adoption scores, large stat figures" }
    },
    "weight": {
      "regular":   { "$value": 400, "$type": "fontWeight", "$css": "NunitoSans-Regular" },
      "semibold":  { "$value": 600, "$type": "fontWeight", "$css": "NunitoSans-SemiBold" },
      "bold":      { "$value": 700, "$type": "fontWeight", "$css": "NunitoSans-Bold" },
      "extrabold": { "$value": 800, "$type": "fontWeight", "$css": "NunitoSans-ExtraBold" }
    },
    "variation": {
      "required": {
        "$value": "\"YTLC\" 500, \"wdth\" 100",
        "$description": "MANDATORY — always apply fontVariationSettings when using Nunito Sans. Without this the font renders incorrectly."
      }
    }
  },

