      "strong":  { "$value": "{color.tertiary.grey}",         "$type": "color", "$description": "Stronger dividers, hover borders" },
      "focus":   { "$value": "{color.primary.cobalt-blue}",   "$type": "color", "$description": "Focus ring — inputs, interactive elements" },
      "error":   { "$value": "{color.secondary.red}",         "$type": "color", "$description": "Error state input borders" }
