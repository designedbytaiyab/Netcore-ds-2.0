      "green":  { "$value": "#00C48C", "$type": "color", "$css-var": "--secondary-green",  "$description": "Success / Live status / Adoption score" },
      "orange": { "$value": "#FFA26B", "$type": "color", "$css-var": "--secondary-orange", "$description": "Peach orange — avatar backgrounds, warm accents" },
