    "channel": {
      "email":    { "$value": "{color.primary.cobalt-blue}", "$type": "color" },
      "sms":      { "$value": "{color.secondary.green}",     "$type": "color" },
      "push":     { "$value": "{color.primary.core-orange}", "$type": "color" },
      "whatsapp": { "$value": "#25D366",                     "$type": "color" },
      "in-app":   { "$value": "#8016F2",                     "$type": "color" },
      "rcs":      { "$value": "#6E70F3",                     "$type": "color" },
      "facebook": { "$value": "#1877F2",                     "$type": "color" },
      "web-push": { "$value": "{color.secondary.yellow}",    "$type": "color" },
