    "text": {
      "charcoal":    { "$value": "#17173A", "$type": "color", "$css-var": "--text-charcoal",    "$description": "Primary text — dark navy. NOT pure black. Use on all light backgrounds." },
      "grey":        { "$value": "{color.tertiary.grey}",        "$type": "color", "$css-var": "--text-grey",        "$description": "Secondary text, body copy in nudges" },
