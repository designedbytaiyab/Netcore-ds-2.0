      "golden":          { "$value": "#FBD233", "$type": "color", "$css-var": "--gradients-primary-golden" },
      "green":           { "$value": "#00E4C0", "$type": "color", "$css-var": "--gradients-primary-green" },
      "orange":          { "$value": "#FFCFA4", "$type": "color", "$css-var": "--gradients-primary-orange" },
      "peach-red":       { "$value": "#FF839F", "$type": "color", "$css-var": "--gradients-primary-peach-red" },
      "purple":          { "$value": "#E08AFA", "$type": "color", "$css-var": "--gradients-primary-purple" },
      "cobalt-blue":     { "$value": "#97BAFF", "$type": "color", "$css-var": "--gradients-primary-cobalt-blue" },
      "fluorescent-blue":{ "$value": "#03AFB9", "$type": "color", "$css-var": "--gradients-primary-fluorescent-blue" },
      "pinkish-red":     { "$value": "#FCA2A2", "$type": "color", "$css-var": "--gradients-primary-pinkish-red" },
      "sky-blue":        { "$value": "#18C2FF", "$type": "color", "$css-var": "--gradients-primary-sky-blue" },
      "sun-orange":      { "$value": "#E76D11", "$type": "color", "$css-var": "--gradients-primary-sun-orange" },
      "yellow":          { "$value": "#FFE995", "$type": "color", "$css-var": "--gradients-primary-yellow" }
