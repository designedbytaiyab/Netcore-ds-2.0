      "link":        { "$value": "{color.primary.cobalt-blue}",  "$type": "color",                                   "$description": "Hyperlinks, anchor text" },
      "success":     { "$value": "{color.secondary.green}",      "$type": "color",                                   "$description": "Success / positive metric text" },
      "error":       { "$value": "{color.secondary.red}",        "$type": "color",                                   "$description": "Error messages, validation text" }
    },

    "surface": {
      "primary":   { "$value": "{color.monochrome.white}",     "$type": "color", "$description": "Default page/card background" },
      "secondary": { "$value": "{color.tertiary.chalk}",       "$type": "color", "$description": "Side nav L2, table headers, subtle panels" },
      "tinted":    { "$value": "{color.tertiary.light-blue-bg}","$type": "color", "$description": "Badge backgrounds, CEE label, info panels" },
      "inverse":   { "$value": "{color.primary.cobalt-blue}",  "$type": "color", "$description": "Dark CTAs, filled nav active items" },
      "dark-nav":  { "$value": "#17173A",                      "$type": "color", "$description": "Left Navigation Primary (IA L1) — dark navy background" }
    },

    "border": {
